{
  "name": "groomer-automation",
  "version": "1.0.0",
  "description": "Headless automation engine for pet grooming salons — connects MoeGo webhooks to SMS alerts via Twilio",
  "main": "webhook_receiver.js",
  "scripts": {
    "start": "node webhook_receiver.js",
    "dev": "nodemon webhook_receiver.js",
    "test:ui": "npx playwright test",
    "test:ui:headed": "npx playwright test --headed",
    "test:ui:report": "npx playwright show-report tests/ui-results/html",
    "demo:record": "npx playwright test --config=playwright.demo.config.ts",
    "demo:record:headed": "npx playwright test --config=playwright.demo.config.ts --headed"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "twilio": "^5.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contactusai77-dot/groomnice.git"
  },
  "keywords": [],
