# ── App ───────────────────────────────────────────────────────────────────────
# Full public URL of your Railway deployment (no trailing slash)
BASE_URL=https://your-app.up.railway.app

# Port — Railway sets this automatically, leave blank locally
PORT=8000

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
# Get this after setting up the webhook in Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Anthropic (Claude vision for vaccine OCR) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use SQLite (fine for solo/beta use)
# For production scale: postgresql://user:pass@host/dbname
DATABASE_URL=
